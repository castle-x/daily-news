{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://castle-x.github.io/daily-news/schemas/news-item.schema.json",
  "title": "DailyNewsItem",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "date",
    "category",
    "title",
    "summary",
    "observations",
    "quote",
    "links"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\d{4}-\\d{2}-\\d{2}-(ai|social-trends|miscellaneous)$"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "category": {
      "type": "string",
      "enum": ["ai", "social-trends", "miscellaneous"]
    },
    "title": {
      "$ref": "#/$defs/localizedText"
    },
    "summary": {
      "$ref": "#/$defs/localizedText"
    },
    "observations": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/localizedText"
      }
    },
    "quote": {
      "$ref": "#/$defs/localizedText"
    },
    "links": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "url", "domain"],
        "properties": {
          "title": {
            "$ref": "#/$defs/localizedText"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "pattern": "^https?://"
          },
          "domain": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    }
  },
  "$defs": {
    "localizedText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["en", "zh"],
      "properties": {
        "en": {
          "type": "string",
          "minLength": 1
        },
        "zh": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
